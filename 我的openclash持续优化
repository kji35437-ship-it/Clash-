mixed-port: 7893
allow-lan: true
bind-address: "*"

mode: rule
log-level: warning

external-controller: 0.0.0.0:9090
skip-certificate-verification: true

tcp-concurrent: true
unified-delay: true
find-process-mode: strict
global-client-fingerprint: chrome

ipv6: false
geodata-mode: true

profile:
  store-selected: true
  store-fake-ip: true

dns:
  enable: true
  listen: 127.0.0.1:7875
  ipv6: false

  enhanced-mode: fake-ip
  fake-ip-range: 198.18.0.1/16

  use-hosts: true

  default-nameserver:
    - 223.5.5.5
    - 114.114.114.114

  nameserver:
    - https://223.5.5.5/dns-query
    - https://dns.alidns.com/dns-query

  fallback:
    - https://1.1.1.1/dns-query
    - https://8.8.8.8/dns-query
    - tls://1.0.0.1:853

  fallback-filter:
    geoip: true
    geoip-code: CN

  fake-ip-filter:
    - "*.lan"
    - "*.local"
    - time.windows.com
    - time.apple.com
    - stun.*
    - stun.*.*
    - "+.msftconnecttest.com"
    - "+.msftncsi.com"
    - geosite:cn

tun:
  enable: true
  stack: mixed
  auto-route: true
  auto-detect-interface: true

  dns-hijack:
    - any:53

